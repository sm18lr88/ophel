{
  "name": "ophel",
  "displayName": "Ophel Atlas - AI Chat Organizer & Navigator",
  "version": "1.0.14",
  "description": "Turn AI chats into readable, navigable knowledge. Use outlines, folders, and prompts to organize your workflow and stop scrolling.",
  "author": "sm18lr88",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sm18lr88/ophel.git"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "plasmo dev",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "build:all": "plasmo build && plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv3",
    "package:all": "plasmo package && plasmo package --target=firefox-mv3",
    "dev:userscript": "vite --config vite.userscript.config.ts",
    "build:userscript": "vite build --config vite.userscript.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "audit:deps": "pnpm audit --json",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@plasmohq/storage": "file:vendor/deps/@plasmohq/storage",
    "effect": "file:vendor/deps/effect",
    "fuzzysort": "file:vendor/deps/fuzzysort",
    "highlight.js": "file:vendor/deps/highlight.js",
    "markdown-it": "file:vendor/deps/markdown-it",
    "markdown-it-anchor": "file:vendor/deps/markdown-it-anchor",
    "markdown-it-container": "file:vendor/deps/markdown-it-container",
    "markdown-it-emoji": "file:vendor/deps/markdown-it-emoji",
    "markdown-it-mark": "file:vendor/deps/markdown-it-mark",
    "markdown-it-task-lists": "file:vendor/deps/markdown-it-task-lists",
    "plasmo": "file:vendor/deps/plasmo",
    "react": "file:vendor/deps/react",
    "react-dom": "file:vendor/deps/react-dom",
    "react-simple-code-editor": "file:vendor/deps/react-simple-code-editor",
    "zustand": "file:vendor/deps/zustand"
  },
  "devDependencies": {
    "@commitlint/cli": "file:vendor/deps/@commitlint/cli",
    "@commitlint/config-conventional": "file:vendor/deps/@commitlint/config-conventional",
    "@types/chrome": "file:vendor/deps/@types/chrome",
    "@types/markdown-it": "file:vendor/deps/@types/markdown-it",
    "@types/node": "file:vendor/deps/@types/node",
    "@types/react": "file:vendor/deps/@types/react",
    "@types/react-dom": "file:vendor/deps/@types/react-dom",
    "@typescript-eslint/eslint-plugin": "file:vendor/deps/@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser": "file:vendor/deps/@typescript-eslint/parser",
    "@vitejs/plugin-react": "file:vendor/deps/@vitejs/plugin-react",
    "eslint": "file:vendor/deps/eslint",
    "eslint-config-prettier": "file:vendor/deps/eslint-config-prettier",
    "eslint-plugin-react": "file:vendor/deps/eslint-plugin-react",
    "eslint-plugin-react-hooks": "file:vendor/deps/eslint-plugin-react-hooks",
    "husky": "file:vendor/deps/husky",
    "lint-staged": "file:vendor/deps/lint-staged",
    "prettier": "file:vendor/deps/prettier",
    "terser": "file:vendor/deps/terser",
    "typescript": "file:vendor/deps/typescript",
    "vite": "file:vendor/deps/vite",
    "vite-plugin-monkey": "file:vendor/deps/vite-plugin-monkey",
    "vitepress": "file:vendor/deps/vitepress"
  },
  "manifest": {
    "name": "__MSG_extensionName__",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "key": "",
    "browser_specific_settings": {
      "gecko": {
        "id": "igodu.love@gmail.com",
        "strict_min_version": "109.0",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    },
    "permissions": [
      "storage",
      "declarativeNetRequestWithHostAccess"
    ],
    "optional_permissions": [
      "notifications",
      "cookies"
    ],
    "host_permissions": [
      "https://gemini.google.com/*",
      "https://business.gemini.google/*",
      "https://aistudio.google.com/*",
      "https://*.googleusercontent.com/*",
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://grok.com/*",
      "https://claude.ai/*"
    ],
    "optional_host_permissions": [
      "https://*/*"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*"
        ],
        "matches": [
          "https://gemini.google.com/*",
          "https://business.gemini.google/*",
          "https://aistudio.google.com/*",
          "https://chatgpt.com/*",
          "https://chat.openai.com/*",
          "https://grok.com/*",
          "https://claude.ai/*"
        ]
      }
    ],
    "commands": {
      "open-global-url": {
        "suggested_key": {
          "default": "Alt+G",
          "mac": "Alt+G"
        },
        "description": "Open Global URL"
      }
    }
  }
}
